# API Configuration
# Update this to match your backend server URL and port
VITE_API_BASE_URL=http://localhost:8000

# Geoapify API Key (for frontend map display - optional, can use OpenStreetMap tiles without key)
# Get your free API key from: https://www.geoapify.com/
VITE_GEOAPIFY_API_KEY=your_geoapify_api_key_here
